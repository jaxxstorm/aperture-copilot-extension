{
	"name": "aperture-copilot-extension",
	"displayName": "Aperture Copilot",
	"description": "Use Tailscale Aperture-served models in VS Code Chat and Copilot Chat.",
	"version": "0.0.3",
	"publisher": "jaxxstorm",
	"license": "MIT",
	"icon": "logo-light.png",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished",
		"onLanguageModelChatProvider:aperture-copilot"
	],
	"main": "./out/src/extension.js",
	"enabledApiProposals": [
		"chatProvider"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/jaxxstorm/aperture-copilot-extension.git"
	},
	"contributes": {
		"commands": [
			{
				"command": "aperture.configure",
				"title": "Aperture Copilot: Configure Aperture"
			},
			{
				"command": "aperture.refreshModels",
				"title": "Aperture Copilot: Refresh Aperture Models"
			},
			{
				"command": "aperture.showRegisteredModels",
				"title": "Aperture Copilot: Show Registered Models"
			}
		],
		"languageModelChatProviders": [
			{
				"vendor": "aperture-copilot",
				"displayName": "Aperture"
			}
		],
		"configuration": {
			"title": "Aperture Copilot",
			"properties": {
				"aperture.baseUrl": {
					"type": "string",
					"default": "",
					"description": "Base URL for the Tailscale Aperture API, for example http://ai."
				},
				"aperture.providerId": {
					"type": "string",
					"default": "aperture",
					"description": "Provider identity used for Aperture-discovered model entries."
				},
				"aperture.models": {
					"type": "array",
					"default": [],
					"description": "Canonical Aperture model entries used by Aperture Copilot.",
					"items": {
						"type": "object",
						"properties": {
							"id": {
								"type": "string",
								"description": "Unique model entry id."
							},
							"name": {
								"type": "string",
								"description": "Display name shown in the model picker."
							},
							"model": {
								"type": "string",
								"description": "Provider model id sent to the upstream API."
							},
							"provider": {
								"type": "string",
								"description": "Provider identity for this model entry."
							},
							"configId": {
								"type": "string",
								"description": "Stable configuration identity used for merges."
							},
							"baseUrl": {
								"type": "string",
								"description": "Base URL used for this model entry."
							},
							"apiKeyName": {
								"type": "string",
								"description": "SecretStorage key containing the credential for this model entry."
							},
							"apiMode": {
								"type": "string",
								"enum": [
									"openai",
									"openai-responses",
									"anthropic",
									"bedrock"
								],
								"description": "Aperture API mode used for provider-native request routing."
							}
						},
						"additionalProperties": true
					}
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint src test --ext .ts",
		"format": "prettier --write .",
		"test": "npm run compile && node --test \"out/test/**/*.test.js\"",
		"build": "vsce package",
		"download-api": "npx @vscode/dts dev"
	},
	"devDependencies": {
		"@eslint/js": "^9.16.0",
		"@stylistic/eslint-plugin": "^2.12.1",
		"@types/node": "^22.10.1",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.2.1",
		"eslint": "^9.16.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.17.0"
	}
}

{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"outDir": "out",
		"rootDir": ".",
		"sourceMap": true,
		"strict": true,
		"moduleResolution": "Node16",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["src", "test"]
}
